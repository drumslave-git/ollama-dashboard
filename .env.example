# Dashboard URL port (Vite in dev, unified app in production)
PORT=3000
OLLAMA_HOST=http://localhost:11434
# Internal API port during `npm run dev` only (default: 3001)
# PROXY_PORT=3001
# Total GPU VRAM in GiB (required for VRAM usage bar and percentage)
# GPU_VRAM_TOTAL_GB=24

# Docker: docker compose up --build  (only port 3000 is published)
# Remote Ollama example: OLLAMA_HOST=https://ollama.example.com docker compose up
