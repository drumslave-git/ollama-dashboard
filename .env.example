# Dashboard URL port (Vite in dev, unified app in production)
PORT=3000
OLLAMA_HOST=http://localhost:11434
# Internal API proxy port used only during `npm run dev` (default: 3001)
# PROXY_PORT=3001
# Total GPU VRAM (GiB) when Ollama does not expose /api/info (common for remote hosts)
# GPU_VRAM_TOTAL_GB=24
